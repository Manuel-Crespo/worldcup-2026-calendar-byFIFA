# FIFA World Cup 2026 Calendar Generator - Environment Variables

# GitHub Pages base URL for public calendar subscription
GITHUB_PAGES_URL=https://yourusername.github.io/worldcup-2026-calendar

# Optional: Override output directory
OUTPUT_DIR=output

# Optional: Default reminder minutes before kickoff
REMINDER_MINUTES=30

# FIFA API Configuration (discovered via reverse engineering)
# Competition ID: 17 = FIFA World Cup
# Season ID: 285023 = FIFA World Cup 2026
# These are built-in defaults — no API key required.
FIFA_API_BASE=https://api.fifa.com/api/v3
FIFA_COMPETITION_ID=17
FIFA_SEASON_ID=285023
