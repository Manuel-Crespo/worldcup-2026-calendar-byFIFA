# FIFA World Cup 2026 Calendar Generator — Environment Variables
#
# Copy this file to .env and update the values:
#   cp .env.example .env

# GitHub Pages base URL (your deployment endpoint)
# Replace with your own GitHub Pages URL
GITHUB_PAGES_URL=https://<username>.github.io/<repo-name>

# Output directory for generated .ics files
OUTPUT_DIR=output

# Reminder minutes before kickoff
REMINDER_MINUTES=30

# FIFA API Configuration (no API key needed — public endpoint)
# These are built-in defaults, only change if FIFA changes their API
FIFA_API_BASE=https://api.fifa.com/api/v3
FIFA_COMPETITION_ID=17
FIFA_SEASON_ID=285023
